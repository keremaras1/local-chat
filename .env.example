# Copy this file to .env and fill in values before running docker compose.

# A long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=

# The single shared password that gates access to the UI.
APP_PASSWORD=

# Database password used by both the db container and the app's connection string.
DB_PASSWORD=

# Set by docker-compose.yml automatically; override here only if running outside Docker.
# DATABASE_URL=postgresql+asyncpg://localchat:YOUR_DB_PASSWORD@localhost:5432/localchat

# Ollama runs on the host, not in Docker. Use host.docker.internal so the container
# can reach it. On the Pi this resolves via the extra_hosts mapping in docker-compose.yml.
OLLAMA_HOST=http://host.docker.internal:11434

# Optional: default model for new conversations (must be installed in Ollama).
OLLAMA_DEFAULT_MODEL=

# Max seconds to wait for Ollama to finish a response. Pi is slow — keep this generous.
OLLAMA_TIMEOUT_S=300

LOG_LEVEL=INFO
